    [Authorize]
    [HttpPut("{id:int}/status")]
    public async Task<ActionResult<ApiResponse<BoardingRequestDto>>> UpdateBoardingStatus(int id, [FromBody] UpdateBoardingStatusDto dto)
    {
        try
        {
            var userId = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
            
            var boardingRequest = await _unitOfWork.BoardingRequests.GetWithDetailsAsync(id);
            
            if (boardingRequest == null)
                return NotFound(ApiResponse<BoardingRequestDto>.ErrorResponse("Boarding request not found"));
            
            // Only owner can update status
            if (boardingRequest.OwnerId != userId)
                return Forbid("Only the pet owner can update boarding status");
            
            boardingRequest.Status = dto.Status;
            boardingRequest.UpdatedAt = DateTime.UtcNow;
            
            // Handle pet visibility based on status
            var pet = await _unitOfWork.Pets.GetByIdAsync(boardingRequest.PetId);
            if (pet != null)
            {
                if (dto.Status == "Confirmed")
                {
                    // Hide pet when owner confirms (waiting for payment from customer)
                    pet.IsHidden = true;
                }
                else if (dto.Status == "Declined")
                {
                    // Show pet again when declined
                    pet.IsHidden = false;
                }
                else if (dto.Status == "InProgress")
                {
                    // Pet remains hidden during boarding
                    pet.IsHidden = true;
                }
                else if (dto.Status == "Completed")
                {
                    // Show pet again when boarding is completed
                    pet.IsHidden = false;
                }
                
                await _unitOfWork.Pets.UpdateAsync(pet);
            }
            
            await _unitOfWork.BoardingRequests.UpdateAsync(boardingRequest);
            await _unitOfWork.SaveChangesAsync();

            var response = new BoardingRequestDto
            {
                Id = boardingRequest.Id,
                PetId = boardingRequest.PetId,
                PetName = boardingRequest.Pet?.Name ?? "",
                PetImageUrl = boardingRequest.Pet?.ImageUrl ?? "",
                OwnerId = boardingRequest.OwnerId,
                OwnerName = boardingRequest.Owner?.FullName ?? "",
                CustomerId = boardingRequest.CustomerId,
                CustomerName = boardingRequest.Customer?.FullName ?? "",
                StartDate = boardingRequest.StartDate,
                EndDate = boardingRequest.EndDate,
                PricePerDay = boardingRequest.PricePerDay,
                TotalAmount = boardingRequest.TotalAmount,
                SpecialInstructions = boardingRequest.SpecialInstructions,
                ContactPhone = boardingRequest.ContactPhone,
                ContactAddress = boardingRequest.ContactAddress,
                Status = boardingRequest.Status,
                CreatedAt = boardingRequest.CreatedAt,
                UpdatedAt = boardingRequest.UpdatedAt
            };

            return Ok(ApiResponse<BoardingRequestDto>.SuccessResponse(response));
        }
        catch (Exception ex)
        {
            return StatusCode(500, ApiResponse<BoardingRequestDto>.ErrorResponse($"Internal server error: {ex.Message}"));
        }
    }

    [Authorize]
    [HttpPost("payment")]
    public async Task<ActionResult<ApiResponse<PaymentDto>>> CreateBoardingPayment([FromBody] BoardingPaymentRequestDto dto)
    {
        try
        {
            var userId = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
            
            var boardingRequest = await _unitOfWork.BoardingRequests.GetWithDetailsAsync(dto.BoardingRequestId);
            
            if (boardingRequest == null)
                return NotFound(ApiResponse<PaymentDto>.ErrorResponse("Boarding request not found"));
            
            // Only pet owner can make payment
            if (boardingRequest.OwnerId != userId)
                return Forbid("Only the pet owner can make payment");
            
            if (boardingRequest.Status != "Confirmed")
                return BadRequest(ApiResponse<PaymentDto>.ErrorResponse("Boarding request must be confirmed before payment"));

            var payment = new PaymentTransaction
            {
                UserId = userId,
                TransactionType = "BoardingPayment",
                PaymentMethod = dto.PaymentMethod,
                Amount = boardingRequest.TotalAmount,
                Status = "Pending",
                Description = $"Boarding payment for {boardingRequest.Pet?.Name}",
                ReferenceId = dto.TransactionId,
                Notes = dto.Notes,
                BoardingRequestId = boardingRequest.Id,
                PetId = boardingRequest.PetId
            };

            await _unitOfWork.PaymentTransactions.AddAsync(payment);
            await _unitOfWork.SaveChangesAsync();

            var response = new PaymentDto
            {
                Id = payment.Id,
                SaleRequestId = 0, // Not applicable for boarding
                PaymentMethod = payment.PaymentMethod,
                TransactionId = payment.ReferenceId,
                Status = payment.Status,
                Notes = payment.Notes,
                CreatedAt = payment.CreatedAt,
                UpdatedAt = payment.CompletedAt
            };

            return Ok(ApiResponse<PaymentDto>.SuccessResponse(response));
        }
        catch (Exception ex)
        {
            return StatusCode(500, ApiResponse<PaymentDto>.ErrorResponse($"Internal server error: {ex.Message}"));
        }
    }

    [Authorize]
    [HttpPost("payment-success")]
    public async Task<ActionResult<ApiResponse<BoardingRequestDto>>> HandlePaymentSuccess([FromBody] BoardingPaymentSuccessDto dto)
    {
        try
        {
            var userId = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
            
            var boardingRequest = await _unitOfWork.BoardingRequests.GetWithDetailsAsync(dto.BoardingRequestId);
            
            if (boardingRequest == null)
                return NotFound(ApiResponse<BoardingRequestDto>.ErrorResponse("Boarding request not found"));
            
            // Only pet owner can confirm payment success
            if (boardingRequest.OwnerId != userId)
                return Forbid("Only the pet owner can confirm payment");
            
            if (boardingRequest.Status != "Confirmed")
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Boarding request must be confirmed before payment"));

            // Auto-confirm the boarding request and start boarding
            boardingRequest.Status = "InProgress";
            boardingRequest.UpdatedAt = DateTime.UtcNow;
            
            // Hide pet during boarding
            var pet = await _unitOfWork.Pets.GetByIdAsync(boardingRequest.PetId);
            if (pet != null)
            {
                pet.IsHidden = true; // Hide pet during boarding
                await _unitOfWork.Pets.UpdateAsync(pet);
            }
            
            await _unitOfWork.BoardingRequests.UpdateAsync(boardingRequest);
            await _unitOfWork.SaveChangesAsync();

            // Create notification for the customer (person who will board the pet)
            var notification = new Notification
            {
                UserId = boardingRequest.CustomerId,
                Title = "Yêu cầu giữ dùm đã được xác nhận",
                Body = $"Yêu cầu giữ dùm thú cưng {boardingRequest.Pet?.Name} đã được xác nhận và thanh toán thành công. Bạn có thể bắt đầu giữ dùm từ {boardingRequest.StartDate:dd/MM/yyyy}.",
                IsRead = false,
                CreatedAt = DateTime.UtcNow
            };
            
            await _unitOfWork.Notifications.AddAsync(notification);
            await _unitOfWork.SaveChangesAsync();

            var response = new BoardingRequestDto
            {
                Id = boardingRequest.Id,
                PetId = boardingRequest.PetId,
                PetName = boardingRequest.Pet?.Name ?? "",
                PetImageUrl = boardingRequest.Pet?.ImageUrl ?? "",
                OwnerId = boardingRequest.OwnerId,
                OwnerName = boardingRequest.Owner?.FullName ?? "",
                CustomerId = boardingRequest.CustomerId,
                CustomerName = boardingRequest.Customer?.FullName ?? "",
                StartDate = boardingRequest.StartDate,
                EndDate = boardingRequest.EndDate,
                PricePerDay = boardingRequest.PricePerDay,
                TotalAmount = boardingRequest.TotalAmount,
                SpecialInstructions = boardingRequest.SpecialInstructions,
                ContactPhone = boardingRequest.ContactPhone,
                ContactAddress = boardingRequest.ContactAddress,
                Status = boardingRequest.Status,
                CreatedAt = boardingRequest.CreatedAt,
                UpdatedAt = boardingRequest.UpdatedAt
            };

            return Ok(ApiResponse<BoardingRequestDto>.SuccessResponse(response));
        }
        catch (Exception ex)
        {
            return StatusCode(500, ApiResponse<BoardingRequestDto>.ErrorResponse($"Internal server error: {ex.Message}"));
        }
    }
}