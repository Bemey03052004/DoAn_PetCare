using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using PetCare.DTOs;
using PetCare.Entities;
using PetCare.Repositories;
using System.Security.Claims;

namespace PetCare.Controllers;

[ApiController]
[Route("api/[controller]")]
public class BoardingController : ControllerBase
{
    private readonly IUnitOfWork _unitOfWork;

    public BoardingController(IUnitOfWork unitOfWork)
    {
        _unitOfWork = unitOfWork;
    }

    [Authorize]
    [HttpPost("request")]
    public async Task<ActionResult<ApiResponse<BoardingRequestDto>>> CreateBoardingRequest([FromBody] CreateBoardingRequestDto dto)
    {
        try
        {
            var userId = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
            
            // Verify pet exists and is for boarding
            var pet = await _unitOfWork.Pets.GetByIdAsync(dto.PetId);
            
            if (pet == null)
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Pet not found"));
            
            if (!pet.IsForBoarding)
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Pet is not available for boarding"));
            
            if (pet.OwnerId == userId)
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Cannot board your own pet"));
            
            if (pet.IsAdopted)
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Pet is adopted and not available for boarding"));

            // Validate dates
            if (dto.StartDate >= dto.EndDate)
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Start date must be before end date"));
            
            if (dto.StartDate < DateTime.Today)
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Start date cannot be in the past"));

            // Check if pet is already hidden (has pending boarding request)
            if (pet.IsHidden)
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Pet is currently being considered for boarding by another user"));

            // Check for overlapping requests
            var overlappingRequests = await _unitOfWork.BoardingRequests.GetOverlappingRequestsAsync(dto.PetId, dto.StartDate, dto.EndDate);
            
            if (overlappingRequests.Any())
                return BadRequest(ApiResponse<BoardingRequestDto>.ErrorResponse("Pet is already booked for this period"));

            var pricePerDay = dto.CustomPricePerDay ?? pet.BoardingPricePerDay ?? 0;
            var totalDays = (dto.EndDate - dto.StartDate).Days;
            var totalAmount = pricePerDay * totalDays;

            var boardingRequest = new BoardingRequest
            {
                PetId = dto.PetId,
                OwnerId = pet.OwnerId,
                CustomerId = userId,
                StartDate = dto.StartDate,
                EndDate = dto.EndDate,
                PricePerDay = pricePerDay,
                TotalAmount = totalAmount,
                SpecialInstructions = dto.SpecialInstructions,
                ContactPhone = dto.ContactPhone,
                ContactAddress = dto.ContactAddress,
                Status = "Pending"
            };

            // Don't hide pet yet - only hide when owner confirms
            await _unitOfWork.BoardingRequests.AddAsync(boardingRequest);
            
            // Create chat room for boarding communication
            var chatRoom = new ChatRoom
            {
                User1Id = pet.OwnerId,
                User2Id = userId,
                CreatedAt = DateTime.UtcNow
            };
            await _unitOfWork.ChatRooms.AddAsync(chatRoom);
            
            await _unitOfWork.SaveChangesAsync();

            // Get the chat room ID that was just created
            var chatRoomId = chatRoom.Id;

            // Load related data for response
            var boardingRequestWithDetails = await _unitOfWork.BoardingRequests.GetWithDetailsAsync(boardingRequest.Id);
            if (boardingRequestWithDetails == null)
                return StatusCode(500, ApiResponse<BoardingRequestDto>.ErrorResponse("Failed to load boarding request details"));

            var response = new BoardingRequestDto
            {
                Id = boardingRequestWithDetails.Id,
                PetId = boardingRequestWithDetails.PetId,
                PetName = boardingRequestWithDetails.Pet?.Name ?? "",
                PetImageUrl = boardingRequestWithDetails.Pet?.ImageUrl ?? "",
                OwnerId = boardingRequestWithDetails.OwnerId,
                OwnerName = boardingRequestWithDetails.Owner?.FullName ?? "",
                CustomerId = boardingRequestWithDetails.CustomerId,
                CustomerName = boardingRequestWithDetails.Customer?.FullName ?? "",
                StartDate = boardingRequestWithDetails.StartDate,
                EndDate = boardingRequestWithDetails.EndDate,
                PricePerDay = boardingRequestWithDetails.PricePerDay,
                TotalAmount = boardingRequestWithDetails.TotalAmount,
                SpecialInstructions = boardingRequestWithDetails.SpecialInstructions,
                ContactPhone = boardingRequestWithDetails.ContactPhone,
                ContactAddress = boardingRequestWithDetails.ContactAddress,
                Status = boardingRequestWithDetails.Status,
                CreatedAt = boardingRequestWithDetails.CreatedAt,
                UpdatedAt = boardingRequestWithDetails.UpdatedAt
            };

            return Ok(ApiResponse<BoardingRequestDto>.SuccessResponse(response));
        }
        catch (Exception ex)
        {
            return StatusCode(500, ApiResponse<BoardingRequestDto>.ErrorResponse($"Internal server error: {ex.Message}"));
        }
    }

    [Authorize]
    [HttpGet("my")]
    public async Task<ActionResult<ApiResponse<IEnumerable<BoardingRequestDto>>>> GetMyBoardingRequests()
    {
        try
        {
            var userId = int.Parse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "0");
            
            var customerRequests = await _unitOfWork.BoardingRequests.GetByCustomerIdAsync(userId);
            var ownerRequests = await _unitOfWork.BoardingRequests.GetByOwnerIdAsync(userId);
            
            var allRequests = customerRequests.Concat(ownerRequests)
                .OrderByDescending(br => br.CreatedAt)
                .ToList();

            var response = allRequests.Select(br => new BoardingRequestDto
            {
                Id = br.Id,
                PetId = br.PetId,
                PetName = br.Pet?.Name ?? "",
                PetImageUrl = br.Pet?.ImageUrl ?? "",
                OwnerId = br.OwnerId,
                OwnerName = br.Owner?.FullName ?? "",
                CustomerId = br.CustomerId,
                CustomerName = br.Customer?.FullName ?? "",
                StartDate = br.StartDate,
                EndDate = br.EndDate,
                PricePerDay = br.PricePerDay,
                TotalAmount = br.TotalAmount,
                SpecialInstructions = br.SpecialInstructions,
                ContactPhone = br.ContactPhone,
                ContactAddress = br.ContactAddress,
                Status = br.Status,
                CreatedAt = br.CreatedAt,
                UpdatedAt = br.UpdatedAt
            });

            return Ok(ApiResponse<IEnumerable<BoardingRequestDto>>.SuccessResponse(response));
        }
        catch (Exception ex)
        {
            return StatusCode(500, ApiResponse<IEnumerable<BoardingRequestDto>>.ErrorResponse($"Internal server error: {ex.Message}"));
        }
    }

